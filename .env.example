# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Atlas (recommended): URI WITHOUT a database name at the end
#   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
# Local:
#   mongodb://localhost:27017
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/

# The database name (separate from the URI — avoids connection string issues)
MONGODB_DB=portfolio

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: `openssl rand -hex 32`
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random

# Admin login credentials
ADMIN_EMAIL=aman@example.com
ADMIN_PASSWORD=your-admin-password

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
